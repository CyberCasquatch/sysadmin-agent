# Copy this file to .env and add your Anthropic API key.
# Get a key at https://console.anthropic.com
#
# NEVER commit your actual .env file to Git.
# .env is already in .gitignore — keep it that way.

ANTHROPIC_API_KEY=your-key-here

# Optional: change the port the server runs on (default: 3000)
# PORT=3000
